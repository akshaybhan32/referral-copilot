# Copy to .env and fill in. For local dev, auth is via the Databricks CLI profile.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Lakebase (Postgres) — from `databricks postgres get-endpoint <endpoint>`
LAKEBASE_ENDPOINT=projects/referral-copilot/branches/production/endpoints/primary
PGHOST=your_postgres_host
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require

# Model Serving endpoint for query embeddings (1024-d)
DATABRICKS_SERVING_ENDPOINT_NAME=databricks-gte-large-en

DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=referral-copilot
