# Copy to .env and fill in. For local dev, auth is via the Databricks CLI profile.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Lakebase (Postgres) — from `databricks postgres get-endpoint <endpoint>`
LAKEBASE_ENDPOINT=projects/referral-copilot/branches/production/endpoints/primary
PGHOST=your_postgres_host
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require

# Model Serving endpoints
DATABRICKS_SERVING_ENDPOINT_NAME=databricks-gte-large-en   # default (satisfies the serving plugin)
EMBED_ENDPOINT=databricks-gte-large-en                     # query embeddings (1024-d)
LLM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct        # translate-in / localize-out

# SQL warehouse — for the conversation archive (UC writes) and the validation ETL
DATABRICKS_WAREHOUSE_ID=your_warehouse_id

# Privacy / retention
APP_USER_SALT=change-me                  # salt for the pseudonymous user id
RETENTION_DAYS=90                        # hard-delete health-query data after N days

# Cost dashboard — list-price estimates (USD); override with your tier's rates
PRICE_EMBED_PER_MTOK=0.10
PRICE_LLM_PER_MTOK=1.50
PRICE_LAKEBASE_CU_HOUR=0.50
PRICE_APP_HOUR=0.10

DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=referral-copilot
